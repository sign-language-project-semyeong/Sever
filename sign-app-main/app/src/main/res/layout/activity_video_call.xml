<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- ── 상단 바: 이름 + 번호 + 미니 카메라 ── -->
    <LinearLayout
        android:id="@+id/layout_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A1A1A"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_call_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="연결 중..." />

            <TextView
                android:id="@+id/tv_call_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- 수어 인식용 미니 카메라 -->
        <androidx.camera.view.PreviewView
            android:id="@+id/pv_local_camera"
            android:layout_width="90dp"
            android:layout_height="120dp"
            android:layout_marginEnd="4dp"
            app:scaleType="fillCenter" />
    </LinearLayout>

    <!-- ── 채팅 영역 (STT + 내 문장) ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chat"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="10dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/layout_top_bar"
        app:layout_constraintBottom_toTopOf="@id/layout_word_area"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── 단어 칩 + 문장 생성 버튼 ── -->
    <LinearLayout
        android:id="@+id/layout_word_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp"
        android:elevation="4dp"
        app:layout_constraintBottom_toTopOf="@id/layout_controller">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="인식된 단어"
            android:textColor="#888888"
            android:textSize="11sp"
            android:layout_marginBottom="6dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_words"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true"
                app:chipSpacingHorizontal="4dp" />
        </HorizontalScrollView>

        <Button
            android:id="@+id/btn_generate_sentence"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:text="문장 생성"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_generate_btn"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ── 하단 컨트롤 바 ── -->
    <LinearLayout
        android:id="@+id/layout_controller"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/bg_call_controller"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btn_switch_camera"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_switch_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_weight="1"
            app:tint="#FFFFFF"
            android:alpha="0.8" />

        <ImageButton
            android:id="@+id/btn_mute"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_mic_off"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_weight="1"
            app:tint="#FFFFFF"
            android:alpha="0.4"
            android:scaleType="centerInside" />

        <ImageButton
            android:id="@+id/btn_hangup"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:src="@drawable/ic_call"
            android:background="@drawable/bg_hangup_btn"
            android:layout_weight="1.2" />

        <ImageButton
            android:id="@+id/btn_speaker"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_speaker"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_weight="1"
            app:tint="#FFFFFF"
            android:alpha="1.0"
            android:scaleType="centerInside" />

        <!-- 더미: 레이아웃 균형용 -->
        <View
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- ── 연결 대기 오버레이 ── -->
    <FrameLayout
        android:id="@+id/layout_camera_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC1A1A1A"
        android:elevation="20dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminate="true"
                android:indeterminateTint="#FFFFFF" />

            <TextView
                android:id="@+id/tv_loading_msg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="전화 연결 중..."
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
